# Experiment run artifacts (transient, not for publication)
results/runs/**/*.record.json
results/runs/**/*.checkpoint.state
results/runs/**/*.stdout.data
results/runs/**/*.stderr.log

# Temporary and generated output
results/**/*.bin
results/**/*.tmp
results/**/*.partial

# Large generated results (excluded from git archive)
results/raw/
results/checkpoints/

# Keep gitkeep files
!**/.gitkeep
